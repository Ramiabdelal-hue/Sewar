# Database - Pooled Connection (للاستخدام العادي - أسرع وأكثر استقراراً)
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/database?sslmode=require&pgbouncer=true"

# Database - Direct Connection (للـ Migrations فقط)
DIRECT_DATABASE_URL="postgresql://user:password@host.neon.tech/database?sslmode=require"

# Mollie Payment (optional)
MOLLIE_API_KEY="test_xxxxxxxxxxxxx"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Security (في الإنتاج)
JWT_SECRET="your-super-secret-jwt-key-change-this"
ADMIN_PASSWORD_HASH="$2b$10$..." # استخدم bcrypt لتشفير كلمة المرور

# Rate Limiting (optional - استخدم Redis في الإنتاج)
REDIS_URL="redis://localhost:6379"

# File Upload Limits
MAX_VIDEO_SIZE_MB=100
MAX_AUDIO_SIZE_MB=10
MAX_IMAGE_SIZE_MB=5

# Cloudinary (للصور والفيديوهات)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Twilio SMS - إرسال رسائل تحذيرية للمشتركين
# احصل على بياناتك من: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Alphanumeric Sender ID (max 11 chars, no spaces) - يظهر كاسم المرسل
TWILIO_SENDER_ID=SewRijbewijs
